* {
    font-family: JetBrainsMono Nerd Font;
    font-size: 16px;
    font-weight: bold;
}

window#waybar {
    background-color: #1e1e2e;
}

button {
    box-shadow: inset 0 -3px transparent;
    border-bottom: 3px solid #89dceb;
    border-radius: 0;
}

button:hover {
    box-shadow: inset 0 -3px #cba6f7;
}

#workspaces button {
    padding: 0 6px;
    color: #89dceb;
    border-bottom: 3px solid transparent;
    border-radius: 0;
}

#workspaces button:hover {
    border-bottom: 3px solid #cba6f7;
    box-shadow: none;
}

#workspaces button.empty {
    color: #ffffff;
}

#workspaces button.active {
    color: #89dceb;
    border-bottom: 3px solid #cba6f7;
}

#workspaces button.empty.active {
    color: #74c7ec;
}

#clock,
#battery,
#cpu,
#memory,
#network,
#custom-kernel,
#pulseaudio,
#tray {
    padding: 0 8;
    color: #ffffff;
    border-radius: 0;
}

#window {
    color: #cdd6f4;
}

#window,
#workspaces {
    margin: 0 4px;
}

#clock {
    color: #f38ba8;
    border-bottom: 3px solid #f38ba8;
}

#battery {
    color: #89b4fa;
    border-bottom: 3px solid #89b4fa;
}

#custom-kernel {
    color: #f38ba8;
    border-bottom: 3px solid #f38ba8;
}

#custom-sep {
    color: #45475a;
}

#cpu {
    color: #74c7ec;
    border-bottom: 3px solid #74c7ec;
}

#memory {
    color: #fab387;
    border-bottom: 3px solid #fab387;
}

#network {
    color: #a6d189;
    border-bottom: 3px solid #a6d189;
}

#network.disconnected {
    color: #e78284;
    border-bottom: 3px solid #e78284;
}

#pulseaudio {
    color: #94e2d5;
    border-bottom: 3px solid #94e2d5;
}

#pulseaudio.muted {
    color: #a6adc8;
    border-bottom: 3px solid #a6adc8;
}

#tray {
    color: #eba0ac;
}
